# Copy to .env.local and fill in. VITE_* vars are PUBLIC — they are baked into
# the client bundle at build time (configure these in Vercel for deploys). The
# unprefixed keys are SERVER/script-only secrets — never expose them client-side.

# ── Client (baked into the bundle) ────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
VITE_MODAL_CRAWLER_URL=
VITE_MODAL_SCRAPER_URL=

# Clerk (Phase 0). Leave UNSET to keep the current Supabase-auth path — ClerkGate
# stays inert and the Clerk SDK isn't even loaded. Set it (dev/staging first) to
# turn the Clerk provider on. Publishable key is public; find it in the Clerk
# dashboard for app app_3EByJgw5ZlGfOjB5R5G7Jy22eGQ.
VITE_CLERK_PUBLISHABLE_KEY=

# ── Server / scripts only (NEVER prefixed VITE_, never committed) ──────────
# Supabase service role — used by scripts/ (e.g. user export) and edge functions.
SUPABASE_SERVICE_ROLE_KEY=
# Clerk server secret — used by scripts/clerk-migration import + the
# clerk-webhook edge function (to set external_id on native signups).
CLERK_SECRET_KEY=
# svix signing secret for the Clerk webhook endpoint (clerk-webhook edge fn).
CLERK_WEBHOOK_SECRET=
