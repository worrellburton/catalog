{
  "name": "catalogwebapp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "remix vite:dev",
    "build": "remix vite:build",
    "start": "remix-serve ./build/server/index.js",
    "lint": "npx eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "playwright test",
    "check:no-typeof-import": "node scripts/check-no-typeof-import.mjs",
    "check:tdz": "node scripts/check-tdz-forward-refs.mjs --strict",
    "eval:search": "node tests/search/eval-relevance.mjs",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@clerk/clerk-react": "^5.61.8",
    "@remix-run/node": "^2.17.4",
    "@remix-run/react": "^2.17.4",
    "@sentry/remix": "^8.46.0",
    "@supabase/supabase-js": "^2.100.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^1.0.12",
    "gsap": "^3.15.0",
    "heic2any": "^0.0.4",
    "hls.js": "^1.6.16",
    "isbot": "^5.1.36",
    "lenis": "^1.3.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@remix-run/dev": "^2.17.4",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "remix-development-tools": "^4.7.7",
    "terser": "^5.36.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": []
  }
}
